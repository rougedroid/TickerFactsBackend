# TickerFacts example environment variables

APP_NAME=TickerFacts
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
DEBUG=True

SECRET_KEY=replace_with_a_secure_secret
JWT_SECRET_KEY=replace_with_a_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tickerfacts
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/tickerfacts

GOOGLE_CLIENT_ID=replace_with_google_client_id
PIPELINE_API_KEY=replace_with_pipeline_api_key
SEC_USER_AGENT=TickerFacts/1.0
INTERNAL_API_KEY=replace_with_internal_api_key
API_URL=https://api.example.com
REDIS_URL=redis://localhost:6379/0
FINNHUB_API_KEY=replace_with_finnhub_api_key
